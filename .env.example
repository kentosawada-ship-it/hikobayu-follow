# Notion
NOTION_TOKEN=secret_xxxx
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # 取引先マスターDB ID

# Claude API
CLAUDE_API_KEY=sk-ant-xxxx

# Gmail OAuth2（Google Cloud Console で取得）
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Gmail アプリパスワード（Googleアカウント → セキュリティ → 2段階認証 → アプリパスワード）
GMAIL_APP_PASSWORD_COMPANY=xxxx xxxx xxxx xxxx
GMAIL_APP_PASSWORD_KAYO=xxxx xxxx xxxx xxxx
GMAIL_APP_PASSWORD_KENTO=xxxx xxxx xxxx xxxx

# メールアドレス（省略時はデフォルト値を使用）
EMAIL_COMPANY=info@hikobayu.com
EMAIL_KAYO=someco@hikobayu.com
EMAIL_KENTO=kento.sawada@hikobayu.com

# Gmail refresh_token（Render 本番用 — ファイルが消えても再認証不要になる）
# 取得方法: ローカルで一度 OAuth 認証後に gmail-tokens.json を開き、
#           各アカウントの "refresh_token" の値をコピーして貼り付ける
GMAIL_REFRESH_TOKEN_COMPANY=1//xxxx
GMAIL_REFRESH_TOKEN_KAYO=1//xxxx
GMAIL_REFRESH_TOKEN_KENTO=1//xxxx

# OAuth コールバック URL
# ローカル開発: http://localhost:3000/oauth2callback
# Render本番:  https://your-app.onrender.com/oauth2callback
OAUTH_REDIRECT_URL=http://localhost:3000/oauth2callback

# ポート（Render は自動設定するため不要）
# PORT=3000
